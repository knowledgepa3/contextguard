  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "contextguard": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
