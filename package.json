  "repository": {
    "type": "git",
    "url": "https://github.com/ace-consulting/contextguard"
  },
  "homepage": "https://github.com/ace-consulting/contextguard#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  }
